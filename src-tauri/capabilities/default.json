{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default permissions for modstack-installer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:app:default",
    "core:window:default",
    "core:path:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "http:default",
    "http:allow-fetch",
    "os:default",
    "os:allow-platform",
    "shell:default"
  ]
}