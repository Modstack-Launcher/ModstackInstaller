{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Modstack Installer",
  "version": "1.0.1",
  "identifier": "modstack.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Modstack Installer",
        "width": 880,
        "height": 550,
        "resizable": false,
        "center": true,
        "decorations": false,
        "shadow": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}